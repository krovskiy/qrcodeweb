<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Code</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
    
    <style>
        body {
            background: rgb(19, 22.5, 30.5);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif
        }

        .container {
            display: flex;
            align-items: center;
            flex-direction: column;
            border-radius: 12px;
            padding: 40px;
            text-align: center;
            max-width: 500px;
            width: 100%;
        }

        img {
            max-width: 100%;
            height: auto;
            border: 2px solid #2c6c40;
            border-radius: 8px;
            padding: 20px;
            background: rgba(15, 40, 24, 0.5);
            margin-bottom: 30px;
        }

        a[role="button"] {
            background-color: #4db86f;
            color: #0f2818;
            padding: 12px 30px;
            border: none;
            border-radius: 8px;
            text-decoration: none;
            font-weight: bold;
            display: inline-block;
            transition: all 0.3s ease;
        }

        a[role="button"]:hover {
            background-color: #3d9b59;
            box-shadow: 0 4px 12px rgba(77, 184, 111, 0.3);
        }
    </style>
</head>
<body>
    <div class="container">
        <img src="<%= qr_code %>" alt="QR Code">
        <a href="/" role="button">Back</a>
    </div>
</body>
</html>